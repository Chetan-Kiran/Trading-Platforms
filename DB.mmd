erDiagram
    USER ||--o{ TRADE : executes
    USER ||--o{ WALLET : owns
    USER ||--o{ BASKET : creates
    USER ||--o{ AUTOMATION_RULE : defines
    USER ||--o{ POSITION : holds

    ASSET ||--o{ TRADE : "is traded"
    ASSET ||--o{ BASKET_ASSET : "belongs to"
    ASSET ||--o{ POSITION : "tracks"
