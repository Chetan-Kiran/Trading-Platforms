    USER {
        bigint id PK
        string email
        string password
        string role
    }

    TRADE {
        bigint id PK
        bigint user_id FK
        bigint asset_id FK
        decimal quantity
        decimal price
        string side
        timestamp created_at
    }

    WALLET {
        bigint id PK
        bigint user_id FK
        decimal balance
        string currency
    }

    BASKET {
        bigint id PK
        bigint user_id FK
        string name
    }

    AUTOMATION_RULE {
        bigint id PK
        bigint user_id FK
        string symbol
        string condition_type
        decimal target_value
        string status
    }